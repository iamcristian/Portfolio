---
import "@/assets/app.css";
import Header from "@/components/header/Header.astro";
import Sprite from "@/assets/icons.svg?raw";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import Footer from "@/components/footer/Footer.astro";
import Head from "@/components/Head.astro";
import Schema from "@/components/Schema.astro";
import PageTransition from "@/components/ui/PageTransition.astro";

interface Props {
  type: "home" | "blog" | "projects" | "blogPost";
  blogPost?: {
    title: string;
    description: string;
    image: string;
    imageAlt: string;
    publishDate?: Date;
    tags?: string[];
  };
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { type, blogPost } = Astro.props;

const meta = type === "blogPost" ? blogPost! : t("meta")[type];

// Map page types to schema types
const schemaTypeMap = {
  home: "website",
  blog: "blogList",
  projects: "projectList",
  blogPost: "blogPost",
} as const;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="author" content="Cristian Arando" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="robots" href="/robots.txt" />
    <!-- <link rel="manifest" href="/manifest.json" /> -->
    <Head
      lang={lang}
      {...meta}
      type={type === "blogPost" ? "article" : "website"}
      publishDate={blogPost?.publishDate}
      tags={blogPost?.tags}
    />

    <!-- Structured Data for SEO -->
    <Schema
      type={schemaTypeMap[type]}
      lang={lang}
      blogPost={type === "blogPost" && blogPost
        ? {
            title: blogPost.title,
            description: blogPost.description,
            image: blogPost.image,
            publishDate: blogPost.publishDate!,
            author: "Cristian Arando",
            tags: blogPost.tags,
          }
        : undefined}
    />

    <!-- For themes - theme-change library -->
    <script is:inline>
      if (localStorage.getItem("theme") === null) {
        document.documentElement.setAttribute("data-theme", "dark");
      } else
        document.documentElement.setAttribute(
          "data-theme",
          localStorage.getItem("theme"),
        );
    </script>
    <script>
      import { themeChange } from "theme-change";
      themeChange();
    </script>
  </head>
  <body class="antialiased">
    <!-- Icons -->
    <div class="hidden" set:html={Sprite} />

    <!-- Main Layout -->
    <Header isHome={type === "home"} />
    <div class="container mx-auto relative">
      <slot />
    </div>
    <Footer />
    <PageTransition />
  </body>
</html>
