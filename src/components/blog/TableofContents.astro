---
interface Heading {
  slug: string;
  text: string;
  depth: number;
}

interface Props {
  headings: Heading[];
  tableOfContentText: string;
}

const { headings: rawHeadings, tableOfContentText } = Astro.props;

// Filter headings to only show h2 and h3 for cleaner TOC
const headings = (rawHeadings ?? []).filter((heading) => heading.depth <= 3);

// Calculate indentation based on heading depth
function getIndentClass(depth: number): string {
  const indentMap: Record<number, string> = {
    2: "ml-0",
    3: "ml-4",
  };
  return indentMap[depth] ?? "ml-0";
}
---

{
  headings.length > 0 && (
    <nav class="p-6 rounded-xl border" aria-label="Table of contents">
      <div class="flex items-center space-x-2 mb-4">
        <svg class="w-5 h-5" aria-hidden="true">
          <use href="#icon-table-of-contents" />
        </svg>
        <h2 class="font-bold">{tableOfContentText}</h2>
      </div>
      <div class="max-h-96 overflow-y-auto">
        <ul class="space-y-2">
          {headings.map((heading) => (
            <li class={getIndentClass(heading.depth)}>
              <a
                href={`#${heading.slug}`}
                class={`block hover:text-primary transition-colors ${
                  heading.depth <= 2 ? "text-sm font-medium" : "text-sm"
                }`}
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  )
}
