---
/**
 * Reusable Section component
 * Provides consistent section styling across the portfolio
 */

interface Props {
  id: string;
  title?: string;
  height?: "screen" | "auto";
  class?: string;
}

const { id, title, height = "auto", class: className = "" } = Astro.props;

const heightClass =
  height === "screen" ? "min-h-screen flex items-center justify-start" : "";

const baseClass = "relative py-12 lg:py-18 px-4 md:px-8 lg:px-16";
---

<section id={id} class:list={[baseClass, heightClass, className]}>
  {
    title && (
      <h2 class="text-2xl md:text-3xl font-bold text-center tracking-tight mb-6">
        {title}
      </h2>
    )
  }
  <slot />
</section>
