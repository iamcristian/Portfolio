---
/**
 * Reusable SVG Icon component using sprite sheet
 * Usage: <Icon name="github" class="w-6 h-6" />
 */

interface Props {
  name: string;
  class?: string;
  size?: "xs" | "sm" | "md" | "lg" | "xl";
}

const { name, class: className = "", size = "md" } = Astro.props;

const sizeClasses = {
  xs: "w-3 h-3",
  sm: "w-4 h-4",
  md: "w-5 h-5",
  lg: "w-6 h-6",
  xl: "w-8 h-8",
};

const sizeClass = sizeClasses[size];
---

<svg class={`${sizeClass} ${className}`} aria-hidden="true">
  <use href={`#icon-${name}`} />
</svg>
