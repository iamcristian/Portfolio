---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import BlogView from "@/components/blog/BlogView";
import Breadcrumbs from "@/components/ui/Breadcrumbs.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "es" } }];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const contentBlog = t("blog");
const contentBreadcrumbs = t("breadcrumbs");

const allPosts = (
  await getCollection("blog", ({ data }) => {
    return data.language === lang;
  })
)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .map((post) => ({
    ...post.data,
  }));

const tags = [...new Set(allPosts.flatMap((p) => p.tags))];

const breadcrumbItems = [
  { label: contentBreadcrumbs.home, href: `/${lang}` },
  { label: contentBreadcrumbs.blog },
];
---

<Layout type="blog">
  <div class="container pt-24 px-4 md:px-8 lg:px-16 mx-auto">
    <Breadcrumbs items={breadcrumbItems} />

    <BlogView
      client:visible
      posts={allPosts}
      lang={lang}
      tags={tags}
      t={contentBlog}
    />
  </div>
</Layout>
